rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Users ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.userId == request.auth.uid 
          && data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && (data.get('age', 0) is int)
          && (data.get('height', 0) is number)
          && (data.get('weight', 0) is number)
          && (data.get('totalSessions', 0) is int)
          && (data.get('avgAccuracy', 0) is number)
          && (data.get('bestAccuracy', 0) is number)
          && (data.get('updatedAt', request.time) is timestamp);
      }

      allow get: if isSignedIn(); // Allow reading profile for UI
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data)
        && request.resource.data.userId == resource.data.userId;
    }

    // --- Private user sessions ---
    match /users/{userId}/sessions/{sessionId} {
      function isValidSession(data) {
        return data.userId == request.auth.uid
          && (data.get('duration', 0) is number)
          && (data.get('drillName', '') is string)
          && (data.get('score', 0) is number)
          && (data.get('aiFeedback', '') is string)
          && (data.get('videoUrl', '') is string)
          && (data.get('thumbnailUrl', '') is string)
          && (data.get('strengths', []) is list)
          && (data.get('weaknesses', []) is list)
          && (data.get('suggestions', []) is list)
          && (data.get('metrics', {}) is map);
      }

      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidSession(request.resource.data);
      allow update: if isOwner(userId) && isValidSession(request.resource.data)
        && request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(userId);
    }
  }
}
